<UserControl x:Class="XtreamIPTV.Views.MoviesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="420"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.3,0.5" EndPoint="1,1">
                <GradientStop Color="#1D252B" Offset="0.0" />
                <GradientStop Color="White" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>
        <!-- CATEGORY LIST -->
        <ListBox Grid.RowSpan="2" Background="#2B373E" Foreground="White" FontSize="18" BorderThickness="0"
                 ItemsSource="{Binding Categories}" 
                 SelectedItem="{Binding SelectedCategory}"
                 SelectionChanged="ListBox_SelectionChanged_1"
                 DisplayMemberPath="Name" 
                 Height="{Binding ElementName=LayoutRoot, Path=ActualHeight}"/>
        <!-- MOVIE DETAILS -->
        <Canvas Grid.Row="0" Grid.Column="1" x:Name="MovieInfoCanvas" Height="390" >
            <Image Source="{Binding SelectedMovie.Backdrop, TargetNullValue={x:Null}}" Height="420" Canvas.Right="20" Canvas.Top="-15"/>
            <StackPanel Width="800" HorizontalAlignment="Left" VerticalAlignment="Top" >
                <TextBlock Text="{Binding SelectedMovie.Title}" FontSize="25" FontWeight="Bold" TextWrapping="Wrap" Foreground="White" />
                <TextBlock Text="{Binding SelectedMovie.ReleaseInfo}" FontSize="15" TextWrapping="Wrap" Foreground="White" Margin="0,5,0,0" />
                <TextBlock Text="{Binding SelectedMovie.Plot}" FontSize="20" TextWrapping="Wrap" Foreground="White" Margin="0,5,0,0" />
                <TextBlock Text="{Binding SelectedMovie.DirectorInfo}" FontSize="10" TextWrapping="Wrap" Foreground="White" Margin="0,10,0,0"/>
                <TextBlock Text="{Binding SelectedMovie.CastInfo}" FontSize="10" TextWrapping="Wrap" Foreground="White" Margin="0,10,0,0"/>
            </StackPanel>
            <Button x:Name="PlayButton" Content="Play" Width="150" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5" 
                Background="LightBlue" FontWeight="Bold" FontSize="25" Canvas.Bottom="5" Canvas.Left="5" Click="Button_Click"/>
            <Button x:Name="PlayButton2" Content="External" Width="150" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5" 
                Background="LightBlue" FontWeight="Bold" FontSize="25" Canvas.Bottom="5" Canvas.Left="175" Click="PlayButton2_Click"/>
            <Button x:Name="FavoriteButton" Content="Favorite" Width="150" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5" 
                Background="LightBlue" FontWeight="Bold" FontSize="25" Canvas.Bottom="5" Canvas.Left="345" Click="FavoriteButton_Click"/>
            <!--<Button x:Name="DownloadButton" Content="Download" Width="150" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="5" 
                Background="LightBlue" FontWeight="Bold" FontSize="25" Canvas.Bottom="5" Canvas.Left="515"/>-->

            <ToggleButton Name="TogglePopupButton" Content="..." Height="20" Width="30" Canvas.Top="-14" Canvas.Left="0"/>

            <Popup IsOpen="{Binding IsChecked, ElementName=TogglePopupButton}"
                           PlacementTarget="{Binding ElementName=TogglePopupButton}"
                           Placement="Bottom"
                           AllowsTransparency="True" 
                           StaysOpen="False">
                <Border BorderThickness="1" Background="LightBlue" Padding="0">
                    <StackPanel>
                        <Button Content="Sort By Default" Click="DefaultSort_Click"/>
                        <Button Content="Sort By Popularity" Click="PopularitySort_Click"/>
                        <Button Content="Sort By Date" Click="DateSort_Click"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Canvas>
        <!-- MOVIE LIST -->
        <ListBox x:Name="MoviesListBox"  Grid.Row="1" Grid.Column="1" 
                 ItemsSource="{Binding FilteredMovies}" Background="Transparent" BorderThickness="0"
                 SelectedItem="{Binding SelectedMovie}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="ListBox_SelectionChanged" ScrollViewer.ScrollChanged="ListBox_ScrollChanged" >
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"  BorderThickness="5" Margin="0" Padding="0" CornerRadius="2" Background="Transparent">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" Background="Transparent" >
                            <Canvas Height="228" Width="150">
                                <Image Width="150" Source="{Binding Path=Poster, TargetNullValue={x:Null}}" VerticalAlignment="Top" />
                                <TextBlock Canvas.Left="0" Canvas.Top="198" Text="{Binding Path=Rating}" FontSize="20" Background="#7F000000"/>
                                <!--<TextBlock Canvas.Left="0" Canvas.Top="0" Text="{Binding Path=Similiar}" Foreground="Yellow" FontSize="25" Background="#5F000000"/>-->
                            </Canvas>
                            <TextBlock x:Name="titleText" TextWrapping="Wrap" Width="150" Height="50" Text="{Binding Path=Title}" FontSize="15"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True" >
                            <Setter Property="BorderBrush" Value="Black" />
                            <Setter Property="Background" Value="Pink" />
                            <Setter Property="Foreground" Value="Black" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False" >
                            <Setter Property="BorderBrush" Value="White" />
                            <Setter Property="Background" Value="#2B373E" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>
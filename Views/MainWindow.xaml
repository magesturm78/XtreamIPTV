<Window x:Class="XtreamIPTV.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:XtreamIPTV.ViewModels"
        xmlns:controls="clr-namespace:XtreamIPTV.Controls"
        Title="XtreamIPTV" Height="720" Width="1280">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <controls:SideNav Grid.Column="0" Grid.RowSpan="2"/>

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}" Grid.RowSpan="2"/>
    </Grid>
</Window>